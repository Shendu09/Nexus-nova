# LocalStack connection
export AWS_ENDPOINT_URL=http://localhost:4566
export AWS_ACCESS_KEY_ID=test
export AWS_SECRET_ACCESS_KEY=test
export AWS_DEFAULT_REGION=us-east-1

# Flare config -- local overrides
export LOG_GROUP_PATTERNS="/test/app"
export SNS_TOPIC_ARN="arn:aws:sns:us-east-1:000000000000:flare-local"
export LOOKBACK_MINUTES=30
export TOKEN_BUDGET=100000

# Use local sentence-transformers model instead of Bedrock
export CORDON_BACKEND=sentence-transformers
export EMBEDDING_MODEL_ID=all-MiniLM-L6-v2

# Use Gemini for LLM analysis instead of Nova on Bedrock
export NOVA_MODEL_ID=gemini/gemini-2.5-flash
# export GEMINI_API_KEY=<your-key-here>

# Voice pipeline -- disabled locally (Connect not available in LocalStack)
export CONNECT_ENABLED=false
export INCIDENTS_TABLE_NAME=flare-incidents-local
